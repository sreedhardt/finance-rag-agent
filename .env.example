# Required: Gemini API key (https://aistudio.google.com/apikey)
# Used for embeddings (always) and for the agent when LLM_PROVIDER=gemini.
GOOGLE_API_KEY=your-key-here

# Agent LLM provider: gemini (default) or groq.
# Embeddings always use Gemini (Groq has no embeddings API).
# LLM_PROVIDER=groq
# GROQ_API_KEY=your-key-here   # https://console.groq.com/keys

# Optional overrides
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# EMBED_MODEL=gemini-embedding-001
# EMBED_DIM=768
